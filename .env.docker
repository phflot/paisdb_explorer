# Docker Environment Configuration for Abstracts Explorer
# Copy this file to .env and modify as needed

# Data Directory (inside container)
DATA_DIR=/app/data

# Database Configuration
# PostgreSQL database (when using docker-compose with postgres service)
PAPER_DB=postgresql://abstracts:abstracts_password@postgres:5432/abstracts

# For SQLite (standalone/local development), use a file path:
# PAPER_DB=/app/data/abstracts.db

# Embeddings Configuration
# ChromaDB service URL (when using docker-compose with chromadb service)
EMBEDDING_DB=http://chromadb:8000

# For embedded ChromaDB (standalone/local development), use a file path:
# EMBEDDING_DB=/app/chroma_db

# Collection name for embeddings
COLLECTION_NAME=papers

# LLM Backend Configuration
# For host's LM Studio (Docker Desktop on Mac/Windows)
LLM_BACKEND_URL=https://api.helmholtz-blablador.fz-juelich.de

# For host's LM Studio (Podman on Linux)
# LLM_BACKEND_URL=http://host.containers.internal:1234

# For external service (e.g., blablador)
# LLM_BACKEND_URL=https://api.helmholtz-blablador.fz-juelich.de
# LLM_BACKEND_AUTH_TOKEN=REPLACE_WITH_YOUR_ACTUAL_TOKEN

# Model Configuration
CHAT_MODEL=alias-code
EMBEDDING_MODEL=alias-qwen3-8b-embeddings

# PAISDB provider registry used by the model dropdown and database build
# workflow. Inject PAISDB_AI_API_KEY through secrets or the runtime
# environment; do not bake it into images.
PAIS_MODEL_PROVIDERS_CONFIG=/app/config/model_providers.yaml
PAIS_GENERATION_PROVIDER=remote_deepseek_v4_pro
PAIS_GENERATION_FALLBACKS=local_qwen3_coder_30b,remote_mistral_medium35,remote_mistral_small4,remote_mistral_large3
PAIS_LOCAL_QWEN_BASE_URL=http://host.containers.internal:18100/v1
PAIS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
PAIS_EMBEDDING_BASE_URL=http://host.containers.internal:18180/v1

# For LM Studio
# CHAT_MODEL=gemma-3-4b-it-qat
# EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b

# Chat/LLM Settings
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1000

# RAG Settings
MAX_CONTEXT_PAPERS=5
ENABLE_QUERY_REWRITING=true
QUERY_SIMILARITY_THRESHOLD=0.7

# Logging Configuration
# Set log level: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
# Can also be controlled via command-line flags: -v (INFO), -vv (DEBUG)
LOG_LEVEL=INFO
