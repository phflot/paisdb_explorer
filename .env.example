# Abstracts Explorer Configuration
# Copy this file to .env and adjust values as needed

# Data Directory (base directory for all data files)
DATA_DIR=data

# Chat/Language Model Settings
CHAT_MODEL=qwen/qwen3-30b-a3b-2507
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1000

# Embedding Model Settings
EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b

# LLM Backend Configuration
LLM_BACKEND_URL=http://localhost:1234
LLM_BACKEND_AUTH_TOKEN=

# For blablador (recommended for CI/testing):
# CHAT_MODEL=alias-code
# EMBEDDING_MODEL=alias-embedding
# LLM_BACKEND_URL=https://api.helmholtz-blablador.fz-juelich.de
# LLM_BACKEND_AUTH_TOKEN=your_blablador_token_here

# PAISDB evidence-building workflow
# Database initialization does not require any PAIS model settings. Fill these
# before running candidate screening, evidence extraction, or embeddings.
PAIS_SCREEN_MODEL=
PAIS_SCREEN_BASE_URL=
PAIS_SCREEN_AUTH_TOKEN=

# Hosted enrichment/extraction models do not replace the initial benchmark
# screen decision.
PAIS_EVIDENCE_BRIEF_MODEL=
PAIS_EVIDENCE_BRIEF_BASE_URL=
PAIS_EVIDENCE_BRIEF_AUTH_TOKEN=
PAIS_EXTRACTION_MODEL=
PAIS_EXTRACTION_BASE_URL=
PAIS_EXTRACTION_AUTH_TOKEN=

# PAIS evidence embedding endpoint.
PAIS_EMBEDDING_MODEL=
PAIS_EMBEDDING_BASE_URL=
PAIS_EMBEDDING_AUTH_TOKEN=

PAIS_STRUCTURED_OUTPUT_MODE=json_schema
PAIS_ALLOW_ADJUDICATION_ON_INVALID_SCREEN=false

# Database Configuration
# PAPER_DB can be either a database URL or a file path:
#   For PostgreSQL: PAPER_DB=postgresql://user:password@localhost/abstracts
#   For SQLite: PAPER_DB=abstracts.db (or /absolute/path/to/abstracts.db)
# Paths are relative to DATA_DIR unless absolute
PAPER_DB=abstracts.db

# Embedding Database Configuration
# EMBEDDING_DB can be either a URL or a file path:
#   For HTTP ChromaDB: EMBEDDING_DB=http://chromadb:8000
#   For local ChromaDB: EMBEDDING_DB=chroma_db (or /path/to/chroma_db)
# Paths are relative to DATA_DIR unless absolute
EMBEDDING_DB=chroma_db

# Optional: Collection name for embeddings
COLLECTION_NAME=papers

# Optional: Default number of papers for RAG context
MAX_CONTEXT_PAPERS=5

# Query Rewriting Settings
# Enable query rewriting to improve semantic search (true/false)
ENABLE_QUERY_REWRITING=true

# Similarity threshold for determining when to retrieve new papers (0.0-1.0)
# Lower values mean more retrieval, higher values mean more caching
QUERY_SIMILARITY_THRESHOLD=0.7

# Web UI Default Filters
# Pre-select a specific conference and/or year when the web UI loads.
# Leave empty (or omit) to show all conferences/years by default.
# DEFAULT_CONFERENCE=NeurIPS
# DEFAULT_YEAR=2024

# Reverse-proxy hop counts for werkzeug ProxyFix (used when running behind nginx).
# Set each value to the number of reverse-proxy layers in front of the app.
# The default of 1 matches the single nginx layer in docker-compose.yml.
# Set to 0 to disable trusting that particular header (e.g. if not behind a proxy).
# PROXY_X_FOR=1
# PROXY_X_PROTO=1
# PROXY_X_HOST=1
# PROXY_X_PREFIX=1

# Optional: Imprint/legal notice URL shown in the web UI footer.
# If set, a link labelled "Imprint" will appear in the footer.
# Leave empty or unset to hide the imprint link.
IMPRINT_LINK=
